{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hinter",
  "version": "0.1.0",
  "identifier": "1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
  {
    "title": "hinter",
    "width": 800,
    "height": 250,
    "decorations": false,
    "transparent": true,
    "alwaysOnTop": true,
    "resizable": false,
    "maximizable": false,
    "shadow": false 
  }
],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
